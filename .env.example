# Paste the Canvas Calendar Feed URL here.
# Canvas: Account > Settings > Calendar Feed > copy the iCal feed URL.
CANVAS_CALENDAR_FEED_URL=

# Google Calendar settings.
GOOGLE_CALENDAR_ID=primary
GOOGLE_CLIENT_SECRETS_FILE=secrets/google_client_secret.json
GOOGLE_TOKEN_FILE=secrets/google_token.json

# Sync behavior.
TIMEZONE=America/Los_Angeles
LOOKAHEAD_DAYS=120
EVENT_DURATION_MINUTES=30
REMINDER_MINUTES=1440,60

# Keep these broad enough to catch assignments, quizzes, and discussions,
# while skipping office hours and general calendar noise.
INCLUDE_KEYWORDS=assignment,quiz,discussion,exam,paper,reflection,submission,lecture engagement,bluebook
EXCLUDE_KEYWORDS=office hours,ta oh,zoom online meeting
